module project (
    input clk,
    input rst_n,
    output reg [7:0] uo_out
);

reg [15:0] lfsr;
wire feedback;

// Polynomial: x^16 + x^14 + x^13 + x^11 + 1
assign feedback = lfsr[15] ^ lfsr[13] ^ lfsr[12] ^ lfsr[10];

always @(posedge clk or negedge rst_n) begin
    if (!rst_n)
        lfsr <= 16'h0001;
    else
        lfsr <= {lfsr[14:0], feedback};
end

// Output lower 8 bits
always @(*) begin
    uo_out = lfsr[7:0];
end

endmodule
